/* 整体容器 */
.online-container {
  padding: 0 32rpx 60rpx;
  background: #f5f5f5;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 顶部标题区域 */
.header {
  padding: 48rpx 0 32rpx;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #111;
  margin-bottom: 10rpx;
}

.subtitle {
  display: block;
  font-size: 26rpx;
  color: #999;
  font-weight: 400;
}

.version {
  display: block;
  font-size: 22rpx;
  color: #bbb;
  margin-top: 8rpx;
}

/* 操作按钮区域 */
.actions {
  display: flex;
  gap: 16rpx;
  margin-bottom: 40rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 26rpx 0;
  border-radius: 16rpx;
  user-select: none;
}

.action-btn:active {
  opacity: 0.75;
}

.create-btn {
  background: #4f46e5;
  color: #fff;
}

.clear-btn {
  background: #fff;
  color: #666;
  border: 1rpx solid #e5e5e5;
}

.btn-icon {
  font-size: 32rpx;
  margin-right: 10rpx;
  line-height: 1;
}

.btn-text {
  font-size: 28rpx;
  font-weight: 600;
}

/* 房间列表区域 */
.room-list {
  width: 100%;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #999;
  margin-bottom: 16rpx;
  display: block;
}

/* 房间卡片 */
.room-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 24rpx;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  background: #fff;
  box-sizing: border-box;
}

.room-item:active {
  background: #f9f9f9;
}

.room-item:last-child {
  margin-bottom: 0;
}

/* 房间信息 */
.room-main-info {
  flex: 1;
  min-width: 0;
  margin-right: 20rpx;
}

.room-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #111;
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.room-status {
  font-size: 22rpx;
  font-weight: 500;
  color: #22c55e;
  background: #f0fdf4;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  white-space: nowrap;
}

.room-details {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.creator-info {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 24rpx;
  color: #999;
}

.creator-avatar {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: #e5e5e5;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #666;
  font-size: 18rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.time {
  font-size: 24rpx;
  color: #bbb;
}

/* 加入按钮 */
.room-actions {
  flex-shrink: 0;
}

.join-btn {
  background: #4f46e5;
  color: #fff;
  border-radius: 12rpx;
  padding: 16rpx 28rpx;
  font-size: 26rpx;
  font-weight: 600;
  user-select: none;
}

.join-btn:active {
  opacity: 0.75;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 100rpx;
  display: block;
  margin-bottom: 24rpx;
  opacity: 0.4;
}

.empty-text {
  font-size: 32rpx;
  color: #333;
  display: block;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999;
  display: block;
  line-height: 1.7;
}

.empty-action {
  margin-top: 40rpx;
}

.empty-action-btn {
  display: inline-block;
  background: #4f46e5;
  color: #fff;
  border-radius: 50rpx;
  padding: 22rpx 56rpx;
  font-size: 28rpx;
  font-weight: 600;
  user-select: none;
}

.empty-action-btn:active {
  opacity: 0.75;
}

/* 加载状态 */
.loading {
  text-align: center;
  padding: 120rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.loading-icon {
  font-size: 64rpx;
  opacity: 0.4;
}

.loading-text {
  color: #999;
  font-size: 26rpx;
}

/* 创建房间弹窗 */
.modal-mask {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
  padding: 40rpx;
  box-sizing: border-box;
}

.modal-card {
  width: 100%;
  max-width: 640rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx 32rpx 32rpx;
  box-sizing: border-box;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #111;
  margin-bottom: 8rpx;
}

.modal-subtitle {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 28rpx;
}

.modal-input {
  width: 100%;
  height: 80rpx;
  border-radius: 12rpx;
  border: 1rpx solid #e5e5e5;
  padding: 0 20rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #111;
  background: #fafafa;
}

.modal-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 28rpx;
}

.modal-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  user-select: none;
}

.modal-btn:active {
  opacity: 0.75;
}

.cancel-btn {
  background: #f5f5f5;
  color: #666;
}

.confirm-btn {
  background: #4f46e5;
  color: #fff;
}
