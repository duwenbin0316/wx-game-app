page {
  background: #1A1A2E;
}

.online-container {
  padding: 16rpx 20rpx 80rpx;
  background: #1A1A2E;
  min-height: 100vh;
  box-sizing: border-box;
  width: 100%;
}

/* ── 顶部标题 ── */
.header {
  padding: 24rpx 0 20rpx;
  border-bottom: 1rpx solid #2A2A4A;
  margin-bottom: 24rpx;
}

.title {
  display: block;
  font-size: 42rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 6rpx;
  font-family: monospace;
  margin-bottom: 8rpx;
}

.version {
  display: block;
  font-size: 18rpx;
  color: #3A3A6A;
  letter-spacing: 2rpx;
  font-family: monospace;
}

/* ── 入口按钮 ── */
.local-btn {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #1E1E38;
  border: 2rpx solid #2E3A5C;
  border-radius: 0;
  padding: 28rpx 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 4rpx 4rpx 0 #0A0A1A;
  box-sizing: border-box;
}

.local-btn:active {
  opacity: 0.75;
}

.local-btn-main {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.local-btn-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #C0C0E8;
  letter-spacing: 2rpx;
  font-family: monospace;
}

.local-btn-sub {
  font-size: 22rpx;
  color: #4A6FA5;
  letter-spacing: 1rpx;
  font-family: monospace;
}

.local-btn-arrow {
  font-size: 40rpx;
  color: #E8873A;
  line-height: 1;
}

/* ── 房间列表 ── */
.room-list {
  width: 100%;
}

.section-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
  margin-top: 8rpx;
}

.section-title {
  font-size: 20rpx;
  font-weight: 500;
  color: #3A3A6A;
  letter-spacing: 3rpx;
  font-family: monospace;
}

.clear-text {
  font-size: 20rpx;
  color: #3A3A6A;
  letter-spacing: 1rpx;
  font-family: monospace;
}

.clear-text:active {
  color: #E8873A;
}

.section-label {
  display: block;
  font-size: 20rpx;
  font-weight: 500;
  color: #3A3A6A;
  letter-spacing: 3rpx;
  margin-bottom: 16rpx;
  font-family: monospace;
}

/* ── 房间卡片 ── */
.room-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 24rpx;
  background: #1E1E38;
  border: 2rpx solid #2E3A5C;
  border-radius: 0;
  margin-bottom: 12rpx;
  box-shadow: 3rpx 3rpx 0 #0A0A1A;
  box-sizing: border-box;
}

.room-item:active {
  opacity: 0.75;
}

.room-main-info {
  flex: 1;
  min-width: 0;
  margin-right: 20rpx;
}

.room-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #C0C0E8;
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 12rpx;
  letter-spacing: 1rpx;
  font-family: monospace;
}

.room-status {
  font-size: 18rpx;
  font-weight: 500;
  color: #4A6FA5;
  background: rgba(74, 111, 165, 0.12);
  border: 1rpx solid #2E3A5C;
  padding: 4rpx 16rpx;
  white-space: nowrap;
  letter-spacing: 1rpx;
  font-family: monospace;
}

.room-details {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.creator-info {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 20rpx;
  color: #3A3A6A;
  font-family: monospace;
}

.creator-avatar {
  width: 36rpx;
  height: 36rpx;
  background: #2E3A5C;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #4A6FA5;
  font-size: 18rpx;
  font-weight: 600;
  flex-shrink: 0;
  font-family: monospace;
}

.time {
  font-size: 20rpx;
  color: #3A3A6A;
  font-family: monospace;
}

/* ── 加入按钮 ── */
.room-actions {
  flex-shrink: 0;
}

.join-btn {
  background: #E8873A;
  color: #1A1A2E;
  padding: 16rpx 30rpx;
  font-size: 24rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  user-select: none;
  font-family: monospace;
  box-shadow: 3rpx 3rpx 0 #0A0A1A;
}

.join-btn:active {
  opacity: 0.75;
}

/* ── 空状态 ── */
.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
}

.empty-icon {
  font-size: 72rpx;
  display: block;
  margin-bottom: 28rpx;
  opacity: 0.3;
}

.empty-text {
  font-size: 28rpx;
  color: #C0C0E8;
  display: block;
  font-weight: 600;
  margin-bottom: 12rpx;
  letter-spacing: 3rpx;
  font-family: monospace;
}

.empty-hint {
  font-size: 22rpx;
  color: #3A3A6A;
  display: block;
  line-height: 2;
  letter-spacing: 1rpx;
  font-family: monospace;
}

.empty-action {
  margin-top: 48rpx;
}

.empty-action-btn {
  display: inline-block;
  background: #E8873A;
  color: #1A1A2E;
  padding: 22rpx 60rpx;
  font-size: 28rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  user-select: none;
  font-family: monospace;
  box-shadow: 4rpx 4rpx 0 #0A0A1A;
}

.empty-action-btn:active {
  opacity: 0.75;
}

/* ── 加载状态 ── */
.loading {
  text-align: center;
  padding: 120rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.loading-icon {
  font-size: 60rpx;
  opacity: 0.3;
}

.loading-text {
  color: #3A3A6A;
  font-size: 22rpx;
  letter-spacing: 3rpx;
  font-family: monospace;
}

/* ── 弹窗 ── */
.modal-mask {
  position: fixed;
  left: 0; top: 0; right: 0; bottom: 0;
  background: rgba(10, 10, 30, 0.78);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
  padding: 40rpx;
  box-sizing: border-box;
}

.modal-card {
  width: 100%;
  max-width: 640rpx;
  background: rgba(30, 30, 60, 0.97);
  border: 2rpx solid #4A6FA5;
  padding: 44rpx 36rpx 36rpx;
  box-sizing: border-box;
  box-shadow: 6rpx 6rpx 0 #0E0E22, 0 0 40rpx rgba(74,111,165,0.3);
}

.modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 8rpx;
  letter-spacing: 4rpx;
  font-family: monospace;
}

.modal-subtitle {
  font-size: 22rpx;
  color: #4A6FA5;
  margin-bottom: 32rpx;
  letter-spacing: 2rpx;
  font-family: monospace;
}

.modal-input {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid #2E3A5C;
  padding: 0 20rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #C0C0E8;
  background: #16162E;
  font-family: monospace;
}

.modal-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 32rpx;
}

.modal-btn {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  user-select: none;
  font-family: monospace;
  box-shadow: 3rpx 3rpx 0 #0E0E22;
}

.modal-btn:active {
  opacity: 0.75;
}

.cancel-btn {
  background: #1E1E38;
  color: #4A6FA5;
  border: 2rpx solid #2E3A5C;
}

.confirm-btn {
  background: #E8873A;
  color: #1A1A2E;
}

/* ── 本地对战弹窗内组件 ── */
.local-mode-btn {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #16162E;
  border: 2rpx solid #2E3A5C;
  padding: 24rpx 20rpx;
  margin-bottom: 20rpx;
}

.local-mode-btn:active {
  opacity: 0.75;
}

.local-mode-main {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.local-mode-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #C0C0E8;
  letter-spacing: 2rpx;
  font-family: monospace;
}

.local-mode-desc {
  font-size: 22rpx;
  color: #4A6FA5;
  font-family: monospace;
}

.local-difficulty-row {
  display: flex;
  gap: 12rpx;
}

.diff-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #16162E;
  border: 2rpx solid #2E3A5C;
  padding: 22rpx 0;
  gap: 8rpx;
  user-select: none;
}

.diff-btn:active {
  border-color: #E8873A;
  opacity: 0.85;
}

.diff-name {
  font-size: 26rpx;
  font-weight: 700;
  color: #C0C0E8;
  letter-spacing: 2rpx;
  font-family: monospace;
}

.diff-desc {
  font-size: 20rpx;
  color: #3A3A6A;
  font-family: monospace;
}
