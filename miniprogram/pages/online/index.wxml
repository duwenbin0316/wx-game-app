<view class="online-container">
  <!-- 顶部标题 -->
  <view class="header">
    <text class="title">五子棋</text>
    <text class="version">v{{version}}</text>
  </view>

  <!-- 单机入口 -->
  <view class="local-btn" bindtap="onLocalGame">
    <view class="local-btn-main">
      <text class="local-btn-title">本地对战</text>
      <text class="local-btn-sub">双人同屏 / 人机对战</text>
    </view>
    <text class="local-btn-arrow">›</text>
  </view>

  <!-- 本地对战模式选择弹窗 -->
  <view class="modal-mask" wx:if="{{showLocalModal}}" bindtap="onCancelLocalModal">
    <view class="modal-card" catchtap="onModalTap">
      <view class="modal-title">本地对战</view>
      <view class="modal-subtitle">选择对战模式</view>
      <view class="local-mode-btn" bindtap="onStartDual">
        <view class="local-mode-main">
          <text class="local-mode-name">双人对战</text>
          <text class="local-mode-desc">两位玩家轮流落子</text>
        </view>
        <text class="local-btn-arrow">›</text>
      </view>
      <text class="section-label" style="margin-top: 8rpx;">人机对战</text>
      <view class="local-difficulty-row">
        <view class="diff-btn" data-difficulty="easy" bindtap="onStartAi">
          <text class="diff-name">简单</text>
          <text class="diff-desc">随机落子</text>
        </view>
        <view class="diff-btn" data-difficulty="medium" bindtap="onStartAi">
          <text class="diff-name">普通</text>
          <text class="diff-desc">有策略</text>
        </view>
        <view class="diff-btn" data-difficulty="hard" bindtap="onStartAi">
          <text class="diff-name">困难</text>
          <text class="diff-desc">较强</text>
        </view>
      </view>
      <view class="modal-actions" style="margin-top: 28rpx;">
        <view class="modal-btn cancel-btn" bindtap="onCancelLocalModal">取消</view>
      </view>
    </view>
  </view>

  <!-- 联机区域 -->
  <view class="local-btn" bindtap="onCreateRoom">
    <view class="local-btn-main">
      <text class="local-btn-title">联机对战</text>
      <text class="local-btn-sub">创建房间，邀请好友加入</text>
    </view>
    <text class="local-btn-arrow">›</text>
  </view>

  <!-- 创建房间弹窗 -->
  <view class="modal-mask" wx:if="{{showRoomNameModal}}" bindtap="onCancelRoomName">
    <view class="modal-card" catchtap="onModalTap">
      <view class="modal-title">创建房间</view>
      <view class="modal-subtitle">请输入房间名</view>
      <input
        class="modal-input"
        placeholder="例如：好友对战房间"
        maxlength="20"
        value="{{roomNameInput}}"
        bindinput="onRoomNameInput"
      />
      <view class="modal-actions">
        <view class="modal-btn cancel-btn" bindtap="onCancelRoomName">取消</view>
        <view class="modal-btn confirm-btn" bindtap="onConfirmRoomName">创建</view>
      </view>
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="loading" wx:if="{{loading}}">
    <text class="loading-icon">⏳</text>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 房间列表 -->
  <view class="room-list" wx:else>
    <view class="section-title-row">
      <text class="section-title">可用房间</text>
      <text class="clear-text" bindtap="onClearAllRooms">清空</text>
    </view>

    <!-- 空状态 -->
    <view wx:if="{{rooms.length === 0}}" class="empty-state">
      <text class="empty-icon">📭</text>
      <text class="empty-text">暂无房间</text>
      <text class="empty-hint">创建一个新房间<br/>开始游戏吧</text>
      <view class="empty-action">
        <view class="empty-action-btn" bindtap="onCreateRoom">创建房间</view>
      </view>
    </view>

    <!-- 房间卡片 -->
    <view wx:for="{{rooms}}" wx:key="_id" class="room-item">
      <view class="room-main-info">
        <view class="room-name">
          {{item.name}}
          <view class="room-status">等待加入</view>
        </view>
        <view class="room-details">
          <view class="creator-info">
            <view class="creator-avatar">{{item.creatorInfo.nickName.charAt(0)}}</view>
            <text>{{item.creatorInfo.nickName}}</text>
          </view>
          <text class="time">{{item.createdAt}}</text>
        </view>
      </view>
      <view class="room-actions">
        <view class="join-btn" data-room-id="{{item._id}}" data-room-name="{{item.name}}" bindtap="onJoinRoom">
          加入
        </view>
      </view>
    </view>
  </view>
</view>
