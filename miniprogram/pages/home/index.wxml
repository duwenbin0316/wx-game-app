<view class="home-container">
  <!-- 像素角色 Logo 区域 -->
  <view class="header">
    <canvas id="logo-canvas" type="2d" class="logo-canvas"></canvas>
    <text class="title">GAME HUB</text>
    <text class="subtitle">像素游戏大厅</text>
  </view>

  <!-- 游戏列表 -->
  <view class="game-list">
    <text class="section-label">— 全部游戏 —</text>
    <view
      wx:for="{{games}}"
      wx:key="id"
      class="game-card"
      data-url="{{item.url}}"
      bindtap="onTapGame"
    >
      <view class="game-card-main">
        <text class="game-name">{{item.name}}</text>
        <text class="game-desc">{{item.desc}}</text>
      </view>
      <text class="game-arrow">›</text>
    </view>
  </view>
</view>
