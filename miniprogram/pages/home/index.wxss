.home-container {
  padding: 0 36rpx 80rpx;
  background: #1A1A2E;
  min-height: 100vh;
  box-sizing: border-box;
}

/* ── Logo 区域 ── */
.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 64rpx 0 56rpx;
  border-bottom: 2rpx solid #2A2A4A;
  margin-bottom: 52rpx;
}

.logo-canvas {
  width: 160rpx;
  height: 160rpx;
  display: block;
  margin-bottom: 28rpx;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #E8873A;
  letter-spacing: 10rpx;
  font-family: monospace;
  margin-bottom: 10rpx;
}

.subtitle {
  display: block;
  font-size: 22rpx;
  color: #4A6FA5;
  letter-spacing: 4rpx;
  font-family: monospace;
}

/* ── 游戏列表 ── */
.game-list {
  width: 100%;
}

.section-label {
  display: block;
  font-size: 22rpx;
  color: #3A3A6A;
  letter-spacing: 4rpx;
  text-align: center;
  font-family: monospace;
  margin-bottom: 28rpx;
}

/* ── 游戏卡片 ── */
.game-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #1E1E38;
  border: 2rpx solid #2E3A5C;
  border-radius: 0;
  padding: 32rpx 28rpx;
  margin-bottom: 16rpx;
  /* 像素风方角 */
  box-shadow: 4rpx 4rpx 0 #0E0E22;
}

.game-card:active {
  background: #252545;
  box-shadow: 2rpx 2rpx 0 #0E0E22;
  transform: translate(2rpx, 2rpx);
}

.game-card-main {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.game-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #E8E8FF;
  letter-spacing: 2rpx;
  font-family: monospace;
}

.game-desc {
  font-size: 22rpx;
  color: #4A6FA5;
  letter-spacing: 1rpx;
  font-family: monospace;
}

.game-arrow {
  font-size: 52rpx;
  color: #E8873A;
  line-height: 1;
}
