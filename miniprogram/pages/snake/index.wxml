<view class="snake-container" bindtouchstart="onTouchStart" bindtouchmove="onTouchMove" bindtouchend="onTouchEnd">
  <!-- 顶部计分栏 -->
  <view class="stats-bar">
    <view class="stat-block">
      <text class="stat-label">SCORE</text>
      <text class="stat-value">{{score}}</text>
    </view>
    <view class="stat-block">
      <text class="stat-label">BEST</text>
      <text class="stat-value best">{{bestScore}}</text>
    </view>
    <view class="stat-block">
      <text class="stat-label">LENGTH</text>
      <text class="stat-value">{{snakeLen}}</text>
    </view>
  </view>

  <canvas id="snake-canvas" type="2d" class="snake-canvas"></canvas>

  <!-- 方向键 -->
  <view class="dpad">
    <view class="dpad-row">
      <view class="dpad-btn" catchtouchstart="onDirUp">▲</view>
    </view>
    <view class="dpad-row">
      <view class="dpad-btn" catchtouchstart="onDirLeft">◀</view>
      <view class="dpad-spacer"></view>
      <view class="dpad-btn" catchtouchstart="onDirRight">▶</view>
    </view>
    <view class="dpad-row">
      <view class="dpad-btn" catchtouchstart="onDirDown">▼</view>
    </view>
  </view>

  <!-- 开始画面 -->
  <view class="overlay" wx:if="{{gameState === 'idle'}}">
    <view class="overlay-card">
      <text class="overlay-title">Clawd 贪吃蛇</text>
      <text class="overlay-sub">吃掉 BUG · 越吃越长</text>
      <view class="hint-row">
        <text class="hint-text">滑动屏幕或点按方向键拐弯</text>
      </view>
      <text class="hint-small">金色 BUG 限时出现，+5 分</text>
      <view class="start-btn" catchtouchstart="onStart">开始游戏</view>
    </view>
  </view>

  <!-- 结束画面 -->
  <view class="overlay over-overlay" wx:if="{{gameState === 'over'}}">
    <view class="overlay-card over-card">
      <text class="over-title">GAME OVER</text>
      <text class="over-sub">{{overReason}}</text>
      <view class="score-block">
        <text class="score-label">SCORE</text>
        <text class="score-value">{{score}}</text>
      </view>
      <view class="best-block">
        <text class="best-label">BEST</text>
        <text class="best-value">{{bestScore}}</text>
      </view>
      <view class="action-row">
        <view class="retry-btn" catchtouchstart="onRetry">
          <text class="retry-text">再来一次</text>
        </view>
        <button class="snake-share-btn" open-type="share" catchtouchstart="">分享</button>
      </view>
    </view>
  </view>
</view>
