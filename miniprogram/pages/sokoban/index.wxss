page {
  background: #1A1A2E;
}

.sokoban-container {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: #1A1A2E;
  display: flex;
  flex-direction: column;
  touch-action: manipulation;
}

/* ── 顶部信息栏 ── */
.game-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14rpx 32rpx;
  background: #1E1E38;
  border-bottom: 2rpx solid #2E3A5C;
  flex-shrink: 0;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.header-level {
  font-size: 26rpx;
  font-weight: 700;
  color: #C0C0E8;
  letter-spacing: 3rpx;
  font-family: monospace;
}

.header-name {
  font-size: 22rpx;
  color: #4A6FA5;
  font-family: monospace;
}

.header-steps {
  font-size: 22rpx;
  color: #D97757;
  letter-spacing: 1rpx;
  font-family: monospace;
}

.header-select {
  font-size: 22rpx;
  color: #4A6FA5;
  font-family: monospace;
  background: #16162E;
  border: 2rpx solid #2E3A5C;
  padding: 8rpx 20rpx;
  box-shadow: 3rpx 3rpx 0 #0A0A1A;
}

.header-select:active {
  background: rgba(74, 111, 165, 0.2);
}

/* ── 游戏画布 ── */
.sokoban-canvas {
  width: 100%;
  flex: 1;
  display: block;
  min-height: 0;
}

/* ── 控制区 ── */
.controls {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 40rpx 44rpx;
  background: #1E1E38;
  border-top: 2rpx solid #2E3A5C;
  flex-shrink: 0;
}

.dpad {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.dpad-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 6rpx;
}

.dpad-up, .dpad-down, .dpad-left, .dpad-right {
  width: 96rpx;
  height: 96rpx;
  background: #16162E;
  border: 2rpx solid #2E3A5C;
  border-radius: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  user-select: none;
  box-shadow: 3rpx 3rpx 0 #0A0A1A;
}

.dpad-up:active, .dpad-down:active,
.dpad-left:active, .dpad-right:active {
  background: rgba(217, 119, 87, 0.12);
  border-color: #D97757;
}

/* CSS 像素三角箭头 */
.arr { display: block; width: 0; height: 0; }
.arr-up    { border-left: 14rpx solid transparent; border-right: 14rpx solid transparent; border-bottom: 20rpx solid #4A6FA5; }
.arr-down  { border-left: 14rpx solid transparent; border-right: 14rpx solid transparent; border-top:    20rpx solid #4A6FA5; }
.arr-left  { border-top: 14rpx solid transparent; border-bottom: 14rpx solid transparent; border-right:  20rpx solid #4A6FA5; }
.arr-right { border-top: 14rpx solid transparent; border-bottom: 14rpx solid transparent; border-left:   20rpx solid #4A6FA5; }

.dpad-center {
  width: 96rpx;
  height: 96rpx;
}

/* ── 撤销/重开按钮 ── */
.side-btns {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.undo-btn {
  padding: 22rpx 40rpx;
  background: #16162E;
  border: 2rpx solid #2E3A5C;
  border-radius: 0;
  color: #4A6FA5;
  font-size: 26rpx;
  font-family: monospace;
  letter-spacing: 2rpx;
  user-select: none;
  box-shadow: 3rpx 3rpx 0 #0A0A1A;
}

.undo-btn:active {
  background: rgba(74, 111, 165, 0.2);
  border-color: #4A6FA5;
}

/* ── 通关 overlay ── */
.overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(10, 10, 30, 0.78);
  z-index: 10;
}

.win-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 56rpx 56rpx 44rpx;
  background: rgba(30, 30, 60, 0.97);
  border: 2rpx solid #F5C842;
  border-radius: 0;
  min-width: 520rpx;
  box-shadow: 6rpx 6rpx 0 #0E0E22, 0 0 40rpx rgba(245,200,66,0.25);
}

.win-emoji {
  font-size: 64rpx;
  color: #F5C842;
  margin-bottom: 16rpx;
}

.win-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 6rpx;
  font-family: monospace;
  margin-bottom: 14rpx;
}

.win-sub {
  font-size: 22rpx;
  color: #4A6FA5;
  letter-spacing: 2rpx;
  font-family: monospace;
  margin-bottom: 12rpx;
}

.win-best {
  font-size: 22rpx;
  color: #F5C842;
  font-family: monospace;
  margin-bottom: 36rpx;
}

.win-btns {
  display: flex;
  gap: 20rpx;
}

.win-btn {
  padding: 20rpx 44rpx;
  border-radius: 0;
  font-size: 28rpx;
  font-weight: 700;
  font-family: monospace;
  letter-spacing: 3rpx;
  user-select: none;
  box-shadow: 3rpx 3rpx 0 #0E0E22;
}

.retry-btn {
  background: #1E1E38;
  border: 2rpx solid #2E3A5C;
  color: #4A6FA5;
}

.retry-btn:active { opacity: 0.7; }

.next-btn {
  background: #D97757;
  color: #1A1A2E;
}

.next-btn:active { opacity: 0.8; }

/* ── 选关面板 ── */
.select-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 44rpx 36rpx 36rpx;
  background: rgba(30, 30, 60, 0.97);
  border: 2rpx solid #4A6FA5;
  border-radius: 0;
  width: 640rpx;
  box-sizing: border-box;
  box-shadow: 6rpx 6rpx 0 #0E0E22;
}

.select-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #C0C0E8;
  font-family: monospace;
  letter-spacing: 4rpx;
  margin-bottom: 32rpx;
}

.select-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  justify-content: center;
  margin-bottom: 32rpx;
}

.select-item {
  width: 104rpx;
  height: 116rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  background: #16162E;
  border: 2rpx solid #2E3A5C;
  box-shadow: 3rpx 3rpx 0 #0A0A1A;
}

.select-item:active { opacity: 0.7; }

.item-locked { opacity: 0.4; }

.item-current {
  border-color: #D97757;
  background: rgba(217, 119, 87, 0.10);
}

.select-num {
  font-size: 32rpx;
  font-weight: 700;
  color: #D97757;
  font-family: monospace;
}

.select-name {
  font-size: 17rpx;
  color: #4A6FA5;
  font-family: monospace;
}

.select-best {
  font-size: 16rpx;
  color: #F5C842;
  font-family: monospace;
}

.select-close {
  padding: 16rpx 56rpx;
  background: #1E1E38;
  border: 2rpx solid #2E3A5C;
  color: #4A6FA5;
  font-size: 26rpx;
  font-family: monospace;
  box-shadow: 3rpx 3rpx 0 #0E0E22;
}

.select-close:active { opacity: 0.7; }
