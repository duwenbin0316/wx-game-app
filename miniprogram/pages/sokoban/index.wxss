page {
  background: #1A1A2E;
}

.sokoban-container {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: #1A1A2E;
  display: flex;
  flex-direction: column;
  touch-action: manipulation;
}

/* ── 顶部信息栏 ── */
.game-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14rpx 32rpx;
  background: #1E1E38;
  border-bottom: 2rpx solid #2E3A5C;
  flex-shrink: 0;
}

.header-level {
  font-size: 26rpx;
  font-weight: 700;
  color: #C0C0E8;
  letter-spacing: 3rpx;
  font-family: monospace;
}

.header-steps {
  font-size: 24rpx;
  color: #E8873A;
  letter-spacing: 2rpx;
  font-family: monospace;
}

/* ── 游戏画布 ── */
.sokoban-canvas {
  width: 100%;
  flex: 1;
  display: block;
  min-height: 0;
}

/* ── 控制区 ── */
.controls {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 40rpx 44rpx;
  background: #1E1E38;
  border-top: 2rpx solid #2E3A5C;
  flex-shrink: 0;
}

.dpad {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.dpad-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 6rpx;
}

.dpad-up, .dpad-down, .dpad-left, .dpad-right {
  width: 96rpx;
  height: 96rpx;
  background: #16162E;
  border: 2rpx solid #2E3A5C;
  border-radius: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  color: #4A6FA5;
  user-select: none;
  box-shadow: 3rpx 3rpx 0 #0A0A1A;
}

.dpad-up:active, .dpad-down:active,
.dpad-left:active, .dpad-right:active {
  background: rgba(232, 135, 58, 0.12);
  border-color: #E8873A;
  color: #E8873A;
}

.dpad-center {
  width: 96rpx;
  height: 96rpx;
}

/* ── 撤销按钮 ── */
.undo-btn {
  padding: 22rpx 40rpx;
  background: #16162E;
  border: 2rpx solid #2E3A5C;
  border-radius: 0;
  color: #4A6FA5;
  font-size: 26rpx;
  font-family: monospace;
  letter-spacing: 2rpx;
  user-select: none;
  box-shadow: 3rpx 3rpx 0 #0A0A1A;
}

.undo-btn:active {
  background: rgba(74, 111, 165, 0.2);
  border-color: #4A6FA5;
}

/* ── 通关 overlay ── */
.overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(10, 10, 30, 0.78);
  z-index: 10;
}

.win-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 56rpx 56rpx 44rpx;
  background: rgba(30, 30, 60, 0.97);
  border: 2rpx solid #F5C842;
  border-radius: 0;
  min-width: 520rpx;
  box-shadow: 6rpx 6rpx 0 #0E0E22, 0 0 40rpx rgba(245,200,66,0.25);
}

.win-emoji {
  font-size: 64rpx;
  color: #F5C842;
  margin-bottom: 16rpx;
}

.win-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 6rpx;
  font-family: monospace;
  margin-bottom: 14rpx;
}

.win-sub {
  font-size: 22rpx;
  color: #4A6FA5;
  letter-spacing: 2rpx;
  font-family: monospace;
  margin-bottom: 48rpx;
}

.win-btns {
  display: flex;
  gap: 20rpx;
}

.win-btn {
  padding: 20rpx 44rpx;
  border-radius: 0;
  font-size: 28rpx;
  font-weight: 700;
  font-family: monospace;
  letter-spacing: 3rpx;
  user-select: none;
  box-shadow: 3rpx 3rpx 0 #0E0E22;
}

.retry-btn {
  background: #1E1E38;
  border: 2rpx solid #2E3A5C;
  color: #4A6FA5;
}

.retry-btn:active { opacity: 0.7; }

.next-btn {
  background: #E8873A;
  color: #1A1A2E;
}

.next-btn:active { opacity: 0.8; }
