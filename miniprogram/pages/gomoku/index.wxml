<view class="container">
  <view class="game-header">
    <view class="header-top">
      <view class="header-slot header-left">
        <text class="mode-pill">{{mode === 'online' ? (myColor === 'black' ? '你是：黑棋' : '你是：白棋') : (isAiMode ? '人机对战' : '本地对战')}}</text>
      </view>
      <view class="header-slot header-right">
        <text class="status-text {{winner ? 'finished' : (mode === 'online' ? (canPlay ? 'your-turn' : 'waiting') : (isAiMode ? (currentPlayer === 'black' ? 'your-turn' : 'waiting') : ''))}}">{{mode === 'online' ? (winner ? '对局结束' : (canPlay ? '轮到你了' : '等待对手下棋...')) : (isAiMode ? (winner ? '对局结束' : (currentPlayer === 'black' ? '你的回合' : '电脑思考中...')) : '自由对弈')}}</text>
      </view>
    </view>

    <view class="players-row">
      <!-- 小新 / 黑棋 -->
      <view class="player-slot {{currentPlayer === 'black' ? 'active' : 'inactive'}}">
        <image class="char-img {{currentPlayer === 'black' ? 'char-active' : ''}}" src="/images/shinnosuke.png" mode="aspectFit"/>
        <text class="player-name">{{blackName}}</text>
      </view>

      <!-- 中间：棋子 + VS -->
      <view class="vs-block">
        <view class="pieces-row">
          <view class="chess-piece black {{currentPlayer === 'black' ? 'active' : ''}}"></view>
          <text class="vs-text">VS</text>
          <view class="chess-piece white {{currentPlayer === 'white' ? 'active' : ''}}"></view>
        </view>
      </view>

      <!-- 左卫门 / 白棋 -->
      <view class="player-slot {{currentPlayer === 'white' ? 'active' : 'inactive'}}">
        <image class="char-img {{currentPlayer === 'white' ? 'char-active' : ''}}" src="/images/boo.png" mode="aspectFit"/>
        <text class="player-name">{{whiteName}}</text>
      </view>
    </view>
  </view>

  <view class="game-board" bindtap="onBoardTap">
    <view class="board-grid">
      <view class="star-points" aria-hidden="true">
        <view class="star-point star-point-1"></view>
        <view class="star-point star-point-2"></view>
        <view class="star-point star-point-3"></view>
        <view class="star-point star-point-4"></view>
        <view class="star-point star-point-5"></view>
      </view>
      <view class="lines-layer"></view>
      <view class="points-layer" wx:if="{{board.length}}">
        <view wx:for="{{points}}" wx:key="id"
              class="intersection r-{{item.r}} c-{{item.c}}"
              data-row="{{item.r}}"
              data-col="{{item.c}}"
              bindtap="onCellTap">
          <view wx:if="{{board[item.r][item.c] === 'black'}}" class="chess black {{item.id === lastMoveKey ? 'last' : ''}} {{winCellSet[item.id] ? 'win' : ''}}"></view>
          <view wx:if="{{board[item.r][item.c] === 'white'}}" class="chess white {{item.id === lastMoveKey ? 'last' : ''}} {{winCellSet[item.id] ? 'win' : ''}}"></view>
        </view>
      </view>
    </view>
  </view>

  <view class="game-controls">
    <view wx:if="{{mode === 'online'}}" class="leave-btn" bindtap="onLeaveRoom">离开</view>
    <view class="undo-btn {{canUndo ? '' : 'disabled'}}" bindtap="onUndo">
      悔棋<text wx:if="{{mode === 'online'}}">({{undoLeft}})</text>
    </view>
    <view class="restart-btn" bindtap="onRestart">重新开始</view>
  </view>

  <!-- 结果覆盖层 -->
  <view class="result-mask" wx:if="{{showResult}}">
    <view class="result-card">
      <view class="result-icon">{{resultIsWin ? '🏆' : '🎯'}}</view>
      <text class="result-title">{{resultTitle}}</text>
      <text class="result-sub">{{resultSub}}</text>
      <view class="result-actions">
        <view class="result-btn result-restart" bindtap="onResultRestart">再来一局</view>
        <view class="result-btn result-leave" bindtap="onResultLeave">返回大厅</view>
      </view>
    </view>
  </view>
</view>
