.container {
  padding: 20rpx 24rpx 32rpx;
  background: #f5f0e8;
  min-height: 100vh;
  box-sizing: border-box;
  width: 100%;
  align-items: stretch;
}

/* 顶部信息栏 */
.game-header {
  background: #fffef9;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid #e8e0d0;
  width: 100%;
  box-sizing: border-box;
}

.header-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  min-height: 44rpx;
  padding-bottom: 14rpx;
  border-bottom: 1rpx solid #ede8de;
}

.header-slot {
  flex: 1 1 0;
  display: flex;
  align-items: center;
}

.header-left {
  justify-content: flex-start;
}

.header-right {
  justify-content: flex-end;
}

.mode-pill {
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 500;
  color: #6a5f50;
  background: #f0ebe0;
  border: 1rpx solid #d5ccbc;
  letter-spacing: 1rpx;
}

.status-text {
  font-size: 24rpx;
  font-weight: 500;
  letter-spacing: 1rpx;
  color: #bbb0a0;
}

.status-text.waiting {
  color: #b07850;
}

.status-text.your-turn {
  color: #4a6e4e;
}

.status-text.finished {
  color: #6a5f50;
}

/* 玩家行 */
.players-row {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 20rpx;
  margin-top: 16rpx;
}

.player-card {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  padding: 0 16rpx;
  border-radius: 12rpx;
  background: #faf7f2;
  border: 1rpx solid #e8e0d0;
  width: 270rpx;
  box-sizing: border-box;
  gap: 12rpx;
  height: 56rpx;
}

.player-card.active {
  background: #eef4ee;
  border-color: #b5ccb5;
}

.player-card.my-player {
  border-color: #7a9e7e;
}

.player-label {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  font-weight: 500;
  color: #2a2218;
  letter-spacing: 1rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  width: 200rpx;
}

.vs {
  font-size: 24rpx;
  font-weight: 500;
  color: #bbb0a0;
  letter-spacing: 3rpx;
}

.chess-piece {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  box-sizing: border-box;
  flex: 0 0 auto;
}

.chess-piece.black {
  background: radial-gradient(circle at 35% 35%, #5b6470, #111827);
  box-shadow: 0 3rpx 8rpx rgba(0, 0, 0, 0.3);
}

.chess-piece.white {
  background: radial-gradient(circle at 35% 35%, #ffffff, #ddd);
  border: 1rpx solid #ccc;
  box-shadow: 0 3rpx 8rpx rgba(0, 0, 0, 0.15);
}

/* 棋盘 */
.game-board {
  background: #c8955a;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(96, 60, 15, 0.2);
  border: 2rpx solid #b07f48;
  margin-bottom: 24rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.board-grid {
  position: relative;
  width: 100%;
  box-sizing: border-box;
}

.lines-layer {
  position: relative;
  z-index: 1;
}

.star-points {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  z-index: 1;
}

.star-point {
  position: absolute;
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: rgba(60, 36, 10, 0.65);
  transform: translate(-50%, -50%);
}

.star-point-1 { left: 21.4286%; top: 21.4286%; }
.star-point-2 { left: 78.5714%; top: 21.4286%; }
.star-point-3 { left: 50%;      top: 50%; }
.star-point-4 { left: 21.4286%; top: 78.5714%; }
.star-point-5 { left: 78.5714%; top: 78.5714%; }

.board-row {
  display: flex;
}

.board-cell {
  flex: 1 0 0;
  aspect-ratio: 1 / 1;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  background: transparent;
  box-sizing: border-box;
}

.board-cell::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2rpx;
  background: rgba(70, 40, 10, 0.4);
}

.board-cell::after {
  content: '';
  position: absolute;
  left: 0; top: 0; bottom: 0;
  width: 2rpx;
  background: rgba(70, 40, 10, 0.4);
}

.board-row:last-child .board-cell {
  border-bottom: 2rpx solid rgba(70, 40, 10, 0.4);
}

.board-row .board-cell:last-child {
  border-right: 2rpx solid rgba(70, 40, 10, 0.4);
}

.points-layer {
  position: absolute;
  left: 0; top: 0; right: 0; bottom: 0;
  z-index: 2;
  pointer-events: none;
}

.intersection {
  position: absolute;
  width: calc(100% / 14);
  height: calc(100% / 14);
  display: flex;
  align-items: center;
  justify-content: center;
  transform: translate(-50%, -50%);
  pointer-events: auto;
}

.r-0  { top: 0%; }      .r-1  { top: 7.1429%; }
.r-2  { top: 14.2857%; } .r-3  { top: 21.4286%; }
.r-4  { top: 28.5714%; } .r-5  { top: 35.7143%; }
.r-6  { top: 42.8571%; } .r-7  { top: 50%; }
.r-8  { top: 57.1429%; } .r-9  { top: 64.2857%; }
.r-10 { top: 71.4286%; } .r-11 { top: 78.5714%; }
.r-12 { top: 85.7143%; } .r-13 { top: 92.8571%; }
.r-14 { top: 100%; }

.c-0  { left: 0%; }      .c-1  { left: 7.1429%; }
.c-2  { left: 14.2857%; } .c-3  { left: 21.4286%; }
.c-4  { left: 28.5714%; } .c-5  { left: 35.7143%; }
.c-6  { left: 42.8571%; } .c-7  { left: 50%; }
.c-8  { left: 57.1429%; } .c-9  { left: 64.2857%; }
.c-10 { left: 71.4286%; } .c-11 { left: 78.5714%; }
.c-12 { left: 85.7143%; } .c-13 { left: 92.8571%; }
.c-14 { left: 100%; }

.chess {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  z-index: 2;
  position: relative;
  box-sizing: border-box;
}

.chess.black {
  background: radial-gradient(circle at 35% 35%, #4b5563, #0f172a);
  box-shadow: 0 3rpx 8rpx rgba(0, 0, 0, 0.35);
}

.chess.white {
  background: radial-gradient(circle at 35% 35%, #ffffff, #e5e7eb);
  border: 1rpx solid #ccc;
  box-shadow: 0 3rpx 8rpx rgba(0, 0, 0, 0.15);
}

.chess.last::after {
  content: '';
  position: absolute;
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: rgba(210, 50, 50, 0.85);
}

/* 底部操作按钮 */
.game-controls {
  display: flex;
  justify-content: center;
  gap: 16rpx;
}

.restart-btn, .leave-btn, .undo-btn {
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  padding: 18rpx 36rpx;
  user-select: none;
  letter-spacing: 1rpx;
}

.restart-btn {
  background: #4a6e4e;
  color: #f5f0e8;
}

.restart-btn:active {
  opacity: 0.75;
}

.undo-btn {
  background: #fffef9;
  color: #6a5f50;
  border: 1rpx solid #d5ccbc;
}

.undo-btn:active {
  opacity: 0.75;
}

.undo-btn.disabled {
  background: #f0ebe0;
  color: #bbb0a0;
  border-color: #e8e0d0;
}

.leave-btn {
  background: #fffef9;
  color: #b07850;
  border: 1rpx solid #d5ccbc;
}

.leave-btn:active {
  opacity: 0.75;
}

/* 结果覆盖层 */
.result-mask {
  position: fixed;
  left: 0; top: 0; right: 0; bottom: 0;
  background: rgba(42, 34, 24, 0.55);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  padding: 40rpx;
  box-sizing: border-box;
}

.result-card {
  width: 100%;
  max-width: 560rpx;
  background: #fffef9;
  border-radius: 28rpx;
  border: 1rpx solid #e8e0d0;
  padding: 56rpx 40rpx 44rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
}

.result-icon {
  font-size: 88rpx;
  margin-bottom: 24rpx;
  line-height: 1;
}

.result-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #2a2218;
  letter-spacing: 4rpx;
  margin-bottom: 16rpx;
}

.result-sub {
  font-size: 24rpx;
  color: #9a8f80;
  letter-spacing: 2rpx;
  margin-bottom: 48rpx;
}

.result-actions {
  display: flex;
  gap: 16rpx;
  width: 100%;
}

.result-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  user-select: none;
}

.result-btn:active {
  opacity: 0.75;
}

.result-restart {
  background: #4a6e4e;
  color: #f5f0e8;
}

.result-leave {
  background: #ede8de;
  color: #6a5f50;
}
