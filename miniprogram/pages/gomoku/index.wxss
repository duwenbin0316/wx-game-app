.container {
  padding: 16rpx 20rpx 32rpx;
  background: #1A1A2E;
  min-height: 100vh;
  box-sizing: border-box;
  width: 100%;
}

/* ── 顶部信息栏 ── */
.game-header {
  background: #1E1E38;
  border: 2rpx solid #2E3A5C;
  border-radius: 0;
  padding: 18rpx 22rpx;
  margin-bottom: 16rpx;
  width: 100%;
  box-sizing: border-box;
  box-shadow: 4rpx 4rpx 0 #0E0E22;
}

.header-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  min-height: 44rpx;
  padding-bottom: 14rpx;
  border-bottom: 1rpx solid #2A2A4A;
}

.header-slot {
  flex: 1 1 0;
  display: flex;
  align-items: center;
}

.header-left  { justify-content: flex-start; }
.header-right { justify-content: flex-end; }

.mode-pill {
  padding: 6rpx 18rpx;
  border-radius: 0;
  font-size: 22rpx;
  font-weight: 500;
  color: #A78BFA;
  background: rgba(167, 139, 250, 0.1);
  border: 1rpx solid #3A2A5A;
  letter-spacing: 1rpx;
  font-family: monospace;
}

.status-text {
  font-size: 22rpx;
  font-weight: 500;
  letter-spacing: 1rpx;
  color: #3A3A6A;
  font-family: monospace;
}

.status-text.waiting   { color: #4A6FA5; }
.status-text.your-turn { color: #E8873A; }
.status-text.finished  { color: #6A6A9A; }

/* ── 玩家行 ── */
.players-row {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 20rpx;
  margin-top: 14rpx;
}

.player-card {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  padding: 0 16rpx;
  border-radius: 0;
  background: #16162E;
  border: 2rpx solid #2A2A4A;
  width: 270rpx;
  box-sizing: border-box;
  gap: 12rpx;
  height: 56rpx;
}

.player-card.active {
  border-color: #E8873A;
  background: rgba(232, 135, 58, 0.08);
}

.player-card.my-player {
  border-color: #4A6FA5;
}

.player-label {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  font-weight: 600;
  color: #C0C0E8;
  letter-spacing: 1rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  width: 200rpx;
  font-family: monospace;
}

.vs {
  font-size: 22rpx;
  font-weight: 700;
  color: #3A3A6A;
  letter-spacing: 3rpx;
  font-family: monospace;
}

.chess-piece {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  box-sizing: border-box;
  flex: 0 0 auto;
}

.chess-piece.black {
  background: radial-gradient(circle at 35% 35%, #5b6470, #111827);
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.5);
}

.chess-piece.white {
  background: radial-gradient(circle at 35% 35%, #ffffff, #ddd);
  border: 1rpx solid #888;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.3);
}

/* ── 棋盘 ── */
.game-board {
  background: #1C2240;
  border: 2rpx solid #2E3A5C;
  border-radius: 0;
  padding: 24rpx;
  box-shadow: 4rpx 4rpx 0 #0E0E22;
  margin-bottom: 20rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.board-grid {
  position: relative;
  width: 100%;
  box-sizing: border-box;
}

.lines-layer {
  position: relative;
  z-index: 1;
}

.star-points {
  position: absolute;
  left: 0; top: 0; right: 0; bottom: 0;
  pointer-events: none;
  z-index: 1;
}

.star-point {
  position: absolute;
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #4A6FA5;
  transform: translate(-50%, -50%);
}

.star-point-1 { left: 21.4286%; top: 21.4286%; }
.star-point-2 { left: 78.5714%; top: 21.4286%; }
.star-point-3 { left: 50%;      top: 50%; }
.star-point-4 { left: 21.4286%; top: 78.5714%; }
.star-point-5 { left: 78.5714%; top: 78.5714%; }

.board-row { display: flex; }

.board-cell {
  flex: 1 0 0;
  aspect-ratio: 1 / 1;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  background: transparent;
  box-sizing: border-box;
}

.board-cell::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 1rpx;
  background: rgba(74, 111, 165, 0.45);
}

.board-cell::after {
  content: '';
  position: absolute;
  left: 0; top: 0; bottom: 0;
  width: 1rpx;
  background: rgba(74, 111, 165, 0.45);
}

.board-row:last-child .board-cell {
  border-bottom: 1rpx solid rgba(74, 111, 165, 0.45);
}

.board-row .board-cell:last-child {
  border-right: 1rpx solid rgba(74, 111, 165, 0.45);
}

.points-layer {
  position: absolute;
  left: 0; top: 0; right: 0; bottom: 0;
  z-index: 2;
  pointer-events: none;
}

.intersection {
  position: absolute;
  width: calc(100% / 14);
  height: calc(100% / 14);
  display: flex;
  align-items: center;
  justify-content: center;
  transform: translate(-50%, -50%);
  pointer-events: auto;
}

.r-0  { top: 0%; }       .r-1  { top: 7.1429%; }
.r-2  { top: 14.2857%; } .r-3  { top: 21.4286%; }
.r-4  { top: 28.5714%; } .r-5  { top: 35.7143%; }
.r-6  { top: 42.8571%; } .r-7  { top: 50%; }
.r-8  { top: 57.1429%; } .r-9  { top: 64.2857%; }
.r-10 { top: 71.4286%; } .r-11 { top: 78.5714%; }
.r-12 { top: 85.7143%; } .r-13 { top: 92.8571%; }
.r-14 { top: 100%; }

.c-0  { left: 0%; }       .c-1  { left: 7.1429%; }
.c-2  { left: 14.2857%; } .c-3  { left: 21.4286%; }
.c-4  { left: 28.5714%; } .c-5  { left: 35.7143%; }
.c-6  { left: 42.8571%; } .c-7  { left: 50%; }
.c-8  { left: 57.1429%; } .c-9  { left: 64.2857%; }
.c-10 { left: 71.4286%; } .c-11 { left: 78.5714%; }
.c-12 { left: 85.7143%; } .c-13 { left: 92.8571%; }
.c-14 { left: 100%; }

.chess {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  z-index: 2;
  position: relative;
  box-sizing: border-box;
}

.chess.black {
  background: radial-gradient(circle at 35% 35%, #4b5563, #0f172a);
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.5);
}

.chess.white {
  background: radial-gradient(circle at 35% 35%, #ffffff, #e5e7eb);
  border: 1rpx solid #aaa;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.3);
}

.chess.last::after {
  content: '';
  position: absolute;
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  background: rgba(232, 135, 58, 0.9);
}

/* ── 底部按钮 ── */
.game-controls {
  display: flex;
  justify-content: center;
  gap: 12rpx;
}

.restart-btn, .leave-btn, .undo-btn {
  border-radius: 0;
  font-size: 26rpx;
  font-weight: 600;
  padding: 18rpx 32rpx;
  user-select: none;
  letter-spacing: 1rpx;
  font-family: monospace;
  box-shadow: 3rpx 3rpx 0 #0E0E22;
}

.restart-btn {
  background: #E8873A;
  color: #1A1A2E;
}

.restart-btn:active { opacity: 0.75; }

.undo-btn {
  background: #1E1E38;
  color: #4A6FA5;
  border: 2rpx solid #2E3A5C;
}

.undo-btn:active { opacity: 0.75; }

.undo-btn.disabled {
  background: #16162A;
  color: #2A2A4A;
  border-color: #1E1E38;
  box-shadow: none;
}

.leave-btn {
  background: #1E1E38;
  color: #A78BFA;
  border: 2rpx solid #3A2A5A;
}

.leave-btn:active { opacity: 0.75; }

/* ── 结果覆盖层 ── */
.result-mask {
  position: fixed;
  left: 0; top: 0; right: 0; bottom: 0;
  background: rgba(10, 10, 30, 0.78);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  padding: 40rpx;
  box-sizing: border-box;
}

.result-card {
  width: 100%;
  max-width: 560rpx;
  background: rgba(30, 30, 60, 0.97);
  border: 2rpx solid #4A6FA5;
  border-radius: 0;
  padding: 56rpx 40rpx 44rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
  box-shadow: 6rpx 6rpx 0 #0E0E22, 0 0 40rpx rgba(74,111,165,0.3);
}

.result-icon {
  font-size: 72rpx;
  margin-bottom: 20rpx;
  line-height: 1;
}

.result-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 6rpx;
  margin-bottom: 14rpx;
  font-family: monospace;
}

.result-sub {
  font-size: 22rpx;
  color: #4A6FA5;
  letter-spacing: 2rpx;
  margin-bottom: 48rpx;
  font-family: monospace;
}

.result-actions {
  display: flex;
  gap: 16rpx;
  width: 100%;
}

.result-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  user-select: none;
  font-family: monospace;
  box-shadow: 3rpx 3rpx 0 #0E0E22;
}

.result-btn:active { opacity: 0.75; }

.result-restart {
  background: #E8873A;
  color: #1A1A2E;
}

.result-leave {
  background: #1E1E38;
  color: #4A6FA5;
  border: 2rpx solid #2E3A5C;
}
