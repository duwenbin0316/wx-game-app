<view class="tetris-page">
  <!-- 顶部信息栏 -->
  <view class="game-header">
    <view class="header-left">
      <text class="header-lv-label">LV.</text><text class="header-lv-num">{{level}}</text>
    </view>
    <view class="header-center">
      <view class="header-pause-btn" catchtouchstart="onPause" wx:if="{{gameState === 'playing'}}">
        <view class="pause-bar"></view>
        <view class="pause-bar"></view>
      </view>
      <view class="header-pause-btn header-pause-disabled" wx:else></view>
      <view class="header-mute-btn" catchtouchstart="onToggleMute">
        <text class="mute-icon">{{muted ? '🔇' : '🔊'}}</text>
      </view>
    </view>
    <view class="header-right">
      <text class="header-score-label">SCORE</text>
      <text class="header-score">{{score}}</text>
    </view>
  </view>

  <!-- 棋盘 + 侧栏 -->
  <view class="main-area">
    <view class="board-wrap"
          bindtouchstart="onBoardTouchStart"
          bindtouchmove="onBoardTouchMove"
          bindtouchend="onBoardTouchEnd">
      <canvas id="tetris-canvas" type="2d" class="board-canvas"></canvas>
    </view>

    <view class="side-panel">
      <view class="side-section" catchtouchend="onHold">
        <text class="side-label">HOLD</text>
        <canvas id="hold-canvas" type="2d" class="hold-canvas"></canvas>
      </view>

      <view class="side-section">
        <text class="side-label">NEXT</text>
        <canvas id="next-canvas" type="2d" class="next-canvas"></canvas>
      </view>

      <view class="stats">
        <view class="stat-row">
          <text class="stat-label">LINES</text>
          <text class="stat-value">{{lines}}</text>
        </view>
        <view class="stat-row">
          <text class="stat-label">BEST</text>
          <text class="stat-value">{{best}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 操作区:左移动/软降,右旋转/硬降 -->
  <view class="controls" wx:if="{{gameState === 'playing'}}" catchtouchend="noop">
    <view class="ctrl-cluster">
      <view class="ctrl-row">
        <view class="cbtn" catchtouchstart="onLeft" catchtouchend="onMoveEnd" catchtouchcancel="onMoveEnd">
          <view class="arr arr-left"></view>
        </view>
        <view class="cbtn" catchtouchstart="onRight" catchtouchend="onMoveEnd" catchtouchcancel="onMoveEnd">
          <view class="arr arr-right"></view>
        </view>
      </view>
      <view class="ctrl-row">
        <view class="cbtn cbtn-wide" catchtouchstart="onDown" catchtouchend="onDownEnd" catchtouchcancel="onDownEnd">
          <view class="arr arr-down"></view>
          <text class="cbtn-hint">软降</text>
        </view>
      </view>
    </view>

    <view class="ctrl-cluster">
      <view class="ctrl-row">
        <view class="cbtn" catchtouchstart="onRotCCW">
          <text class="rot-glyph">⟲</text>
        </view>
        <view class="cbtn cbtn-rot" catchtouchstart="onRotCW">
          <text class="rot-glyph rot-main">⟳</text>
        </view>
      </view>
      <view class="ctrl-row">
        <view class="cbtn cbtn-wide cbtn-drop" catchtouchstart="onDrop">
          <view class="drop-glyph">
            <view class="arr arr-down drop-arr"></view>
            <view class="drop-bar"></view>
          </view>
          <text class="cbtn-hint hint-drop">硬降</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 暂停 -->
  <view class="overlay" wx:if="{{gameState === 'paused'}}">
    <view class="over-card">
      <text class="over-title">暂停</text>
      <text class="over-best">当前得分 {{score}}</text>
      <view class="restart-btn" catchtouchstart="onResume">继续游戏</view>
      <view class="ghost-btn" catchtouchstart="onRestart">重新开始</view>
    </view>
  </view>

  <!-- 结束 -->
  <view class="overlay" wx:if="{{gameState === 'over'}}">
    <view class="over-card">
      <text class="over-title">游戏结束</text>
      <view class="newbest-badge" wx:if="{{isNewBest}}">
        <text class="newbest-text">★ 新纪录 ★</text>
      </view>
      <text class="over-score-num">{{score}}</text>
      <text class="over-score-label">本局得分</text>
      <text class="over-best">等级 {{level}} · 消行 {{lines}} · 最高 {{best}}</text>
      <view class="restart-btn" catchtouchstart="onRestart">再来一局</view>
      <button class="share-btn" open-type="share">分享战绩</button>
    </view>
  </view>
</view>
