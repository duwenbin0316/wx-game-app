page {
  background: #1A1A2E;
}

.tetris-page {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: #1A1A2E;
  color: #C0C0E8;
  display: flex;
  flex-direction: column;
  font-family: monospace;
  touch-action: manipulation;
}

/* ── 顶部信息栏 ── */
.game-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14rpx 32rpx;
  background: #1E1E38;
  border-bottom: 2rpx solid #2E3A5C;
  flex-shrink: 0;
}

.header-left {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
  min-width: 140rpx;
}

.header-lv-label {
  font-size: 22rpx;
  color: #4A6FA5;
  font-family: monospace;
}

.header-lv-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #F5C842;
  font-family: monospace;
}

.header-center {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.header-pause-btn {
  width: 64rpx;
  height: 64rpx;
  background: #16162E;
  border: 2rpx solid #2E3A5C;
  box-shadow: 3rpx 3rpx 0 #0A0A1A;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.header-pause-btn:active { background: rgba(217, 119, 87, 0.15); }

.header-pause-disabled { opacity: 0.3; }

.pause-bar {
  width: 8rpx;
  height: 28rpx;
  background: #4A6FA5;
}

.header-mute-btn {
  width: 64rpx;
  height: 64rpx;
  background: #16162E;
  border: 2rpx solid #2E3A5C;
  box-shadow: 3rpx 3rpx 0 #0A0A1A;
  display: flex;
  align-items: center;
  justify-content: center;
}

.mute-icon { font-size: 32rpx; }

.header-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  min-width: 140rpx;
}

.header-score-label {
  font-size: 18rpx;
  color: #4A6FA5;
  letter-spacing: 2rpx;
  font-family: monospace;
}

.header-score {
  font-size: 36rpx;
  font-weight: 700;
  color: #D97757;
  font-family: monospace;
}

/* ── 主区域 ── */
.main-area {
  flex: 1;
  display: flex;
  flex-direction: row;
  min-height: 0;
  padding: 12rpx 12rpx 0;
  gap: 10rpx;
}

.board-wrap {
  flex: 1;
  min-width: 0;
}

.board-canvas {
  width: 100%;
  height: 100%;
  display: block;
}

.side-panel {
  width: 168rpx;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  padding-top: 8rpx;
}

.side-section {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.side-label {
  font-size: 20rpx;
  color: #4A6FA5;
  letter-spacing: 3rpx;
  font-family: monospace;
}

.hold-canvas {
  width: 150rpx;
  height: 130rpx;
  display: block;
}

.next-canvas {
  width: 150rpx;
  height: 340rpx;
  display: block;
}

.stats {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-top: 6rpx;
}

.stat-row {
  display: flex;
  flex-direction: column;
}

.stat-label {
  font-size: 18rpx;
  color: #4A6FA5;
  letter-spacing: 2rpx;
  font-family: monospace;
}

.stat-value {
  font-size: 30rpx;
  font-weight: 700;
  color: #C0C0E8;
  font-family: monospace;
}

/* ── 操作区 ── */
.controls {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  padding: 18rpx 28rpx 40rpx;
  background: #1E1E38;
  border-top: 2rpx solid #2E3A5C;
  flex-shrink: 0;
}

.ctrl-cluster {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.ctrl-row {
  display: flex;
  flex-direction: row;
  gap: 14rpx;
}

.cbtn {
  width: 150rpx;
  height: 92rpx;
  background: #16162E;
  border: 2rpx solid #2E3A5C;
  border-radius: 0;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  user-select: none;
  box-shadow: 3rpx 3rpx 0 #0A0A1A;
}

.cbtn:active {
  background: rgba(217, 119, 87, 0.12);
  border-color: #D97757;
}

.cbtn-wide { width: 314rpx; }

.cbtn-rot { border-color: #3A4A75; }

.cbtn-drop { border-color: #7A4432; }

.cbtn-hint {
  font-size: 20rpx;
  color: #4A6FA5;
  font-family: monospace;
  letter-spacing: 2rpx;
}

.hint-drop { color: #D97757; }

/* CSS 像素三角箭头 */
.arr { display: block; width: 0; height: 0; }
.arr-left  { border-top: 14rpx solid transparent; border-bottom: 14rpx solid transparent; border-right: 20rpx solid #4A6FA5; }
.arr-right { border-top: 14rpx solid transparent; border-bottom: 14rpx solid transparent; border-left:  20rpx solid #4A6FA5; }
.arr-down  { border-left: 14rpx solid transparent; border-right: 14rpx solid transparent; border-top:   20rpx solid #4A6FA5; }

.rot-glyph {
  font-size: 44rpx;
  color: #4A6FA5;
  font-family: monospace;
  line-height: 1;
}

.rot-main {
  font-size: 52rpx;
  color: #C0C0E8;
}

.drop-glyph {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.drop-arr { border-top-color: #D97757; }

.drop-bar {
  width: 36rpx;
  height: 6rpx;
  background: #D97757;
}

/* ── 弹层 ── */
.overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(10, 10, 30, 0.78);
  z-index: 10;
}

.over-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 56rpx 64rpx 44rpx;
  background: rgba(30, 30, 60, 0.97);
  border: 2rpx solid #D97757;
  border-radius: 0;
  min-width: 480rpx;
  box-shadow: 6rpx 6rpx 0 #0E0E22;
}

.over-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 8rpx;
  font-family: monospace;
  margin-bottom: 20rpx;
}

.newbest-badge {
  padding: 6rpx 24rpx;
  background: rgba(245, 200, 66, 0.12);
  border: 2rpx solid #F5C842;
  margin-bottom: 16rpx;
}

.newbest-text {
  font-size: 24rpx;
  color: #F5C842;
  font-family: monospace;
  letter-spacing: 2rpx;
}

.over-score-num {
  font-size: 72rpx;
  font-weight: 700;
  color: #F5C842;
  font-family: monospace;
  line-height: 1.1;
}

.over-score-label {
  font-size: 22rpx;
  color: #4A6FA5;
  font-family: monospace;
  margin-bottom: 10rpx;
}

.over-best {
  font-size: 24rpx;
  color: #C0C0E8;
  font-family: monospace;
  margin-bottom: 36rpx;
}

.restart-btn {
  padding: 20rpx 64rpx;
  background: #D97757;
  color: #1A1A2E;
  font-size: 30rpx;
  font-weight: 700;
  font-family: monospace;
  letter-spacing: 4rpx;
  border-radius: 0;
  box-shadow: 3rpx 3rpx 0 #0E0E22;
  user-select: none;
}

.restart-btn:active { opacity: 0.8; }

.ghost-btn {
  margin-top: 20rpx;
  padding: 16rpx 48rpx;
  background: #1E1E38;
  border: 2rpx solid #2E3A5C;
  color: #4A6FA5;
  font-size: 26rpx;
  font-family: monospace;
  letter-spacing: 3rpx;
  border-radius: 0;
  box-shadow: 3rpx 3rpx 0 #0E0E22;
  user-select: none;
}

.ghost-btn:active { opacity: 0.7; }

.share-btn {
  margin-top: 20rpx;
  padding: 10rpx 48rpx;
  background: #1E1E38;
  border: 2rpx solid #4A6FA5;
  color: #4A6FA5;
  font-size: 26rpx;
  font-family: monospace;
  letter-spacing: 3rpx;
  border-radius: 0;
  box-shadow: 3rpx 3rpx 0 #0E0E22;
  line-height: 1.8;
}

.share-btn::after { border: none; }

.share-btn:active { opacity: 0.7; }
